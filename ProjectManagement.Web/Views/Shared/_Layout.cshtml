<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProMana</title>
    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@1.9.10" integrity="sha384-D1Kt99CQMDuVetoL1lrYwg5t+9QdHe7NLX/SoJYkXDFfX37iInKRy5xLSi8nO7UC" crossorigin="anonymous"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif']
                    },
                    colors: {
                        border: "var(--border)",
                        input: "var(--input)",
                        ring: "var(--ring)",
                        background: "var(--background)",
                        foreground: "var(--foreground)",
                        primary: {
                            DEFAULT: "var(--primary)",
                            foreground: "var(--primary-foreground)",
                        },
                        muted: {
                            DEFAULT: "var(--muted)",
                            foreground: "var(--muted-foreground)",
                        },
                        accent: {
                            DEFAULT: "var(--accent)",
                            foreground: "var(--accent-foreground)",
                        }
                    }
                }
            }
        }
    </script>
    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="text-slate-100 font-sans antialiased selection:bg-indigo-500 selection:text-white h-screen flex bg-[#080e1a]" hx-boost="true" hx-indicator="#global-progress">

    <!-- Progress Bar atop the screen -->
    <div id="global-progress" class="htmx-indicator fixed top-0 left-0 w-full h-[2px] bg-slate-900 z-[9999]"></div>

    @{
        bool isHome = ViewContext.RouteData.Values["controller"]?.ToString() == "Home" 
                   && ViewContext.RouteData.Values["action"]?.ToString() == "Index";
    }
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- DASHBOARD SIDEBAR -->
        <aside class="w-64 border-r border-slate-700/50 bg-[#0a1020] flex-shrink-0 flex flex-col h-full z-20">
            <!-- Brand -->
            <div class="h-14 flex items-center px-6 border-b border-slate-700/50">
                <a asp-controller="Projects" asp-action="Index" class="flex items-center gap-2 font-semibold text-lg tracking-tight text-slate-100">
                    <div class="bg-gradient-to-br from-indigo-500 to-purple-600 text-white p-1 rounded-md flex items-center justify-center">
                        <i class="bi bi-hexagon-fill text-[12px]"></i>
                    </div>
                    ProMana
                </a>
            </div>

            <!-- Navigation Links -->
            <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
                <a asp-controller="Projects" asp-action="Index" class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md bg-indigo-500/10 text-indigo-300 border border-indigo-500/20 transition-colors mb-6">
                    <i class="bi bi-grid-fill text-indigo-400"></i> Todos los Proyectos
                </a>
                
                <div class="mt-8 mb-2 px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider flex items-center justify-between">
                    <span>Tus Proyectos</span>
                    <a asp-controller="Projects" asp-action="Create" class="text-slate-500 hover:text-indigo-400 transition-colors" title="Nuevo Proyecto">
                        <i class="bi bi-plus-lg"></i>
                    </a>
                </div>
                
                @using ProjectManagement.Application.Services
                @inject ProjectService ProjectService
                @{
                    var userIdString = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    bool hasUserId = Guid.TryParse(userIdString, out var userId);
                    var (sidebarProjects, _) = hasUserId ? await ProjectService.GetProjectsAsync(null, 1, 50, userId) : (new List<ProjectManagement.Application.DTOs.ProjectDto>(), 0);
                }
                
                @if (!sidebarProjects.Any())
                {
                    <p class="px-3 py-2 text-xs text-slate-500 italic">No hay proyectos activos.</p>
                }
                else
                {
                    <div class="space-y-0.5">
                    @foreach(var p in sidebarProjects) 
                    {
                        <a asp-controller="Projects" asp-action="Details" asp-route-id="@p.Id" class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-slate-400 hover:bg-slate-800/60 hover:text-slate-200 transition-colors group">
                            <span class="w-1.5 h-1.5 rounded-full @(p.Status == ProjectManagement.Domain.Enums.ProjectStatus.Active ? "bg-indigo-500" : (p.Status == ProjectManagement.Domain.Enums.ProjectStatus.Completed ? "bg-emerald-500" : "bg-slate-600")) opacity-70 group-hover:opacity-100"></span>
                            <span class="truncate">@p.Name</span>
                        </a>
                    }
                    </div>
                }
            </nav>

            <!-- User Footer -->
            <div class="p-4 border-t border-slate-700/50">
                <div class="flex items-center gap-3 w-full bg-slate-800/50 px-3 py-2 rounded-md border border-slate-700/50">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-sm font-semibold text-white">
                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-slate-200 truncate">@User.Identity.Name</p>
                    </div>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="text-slate-500 hover:text-red-400 transition-colors" title="Cerrar Sesión">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- DASHBOARD MAIN CONTENT -->
        <div class="flex-1 flex flex-col h-full relative overflow-y-auto bg-[#080e1a] p-6 md:p-10 hide-scrollbar" id="main-content">
            <main class="max-w-6xl mx-auto w-full transition-all duration-300">
                @if (TempData["Success"] != null)
                {
                    <div class="mb-6 rounded-md border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-300 flex items-center gap-3">
                        <i class="bi bi-check-circle-fill text-emerald-400"></i>
                        <span class="font-medium">@TempData["Success"]</span>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="mb-6 rounded-md border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300 flex items-center gap-3">
                        <i class="bi bi-exclamation-triangle-fill text-red-400"></i>
                        <span class="font-medium">@TempData["Error"]</span>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- MARKETING / GUEST LAYOUT -->
        <div class="landing-wrapper w-full flex flex-col overflow-y-auto bg-[#0b1120]">
            @{
                bool isAuth = ViewContext.RouteData.Values["controller"]?.ToString() == "Auth";
            }
            @if (!isHome && !isAuth)
            {
                <header class="guest-header w-full mx-auto max-w-7xl px-6 h-16 flex items-center justify-between relative z-10">
                    <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 font-semibold text-lg tracking-tight text-slate-100">
                        <div class="bg-gradient-to-br from-indigo-500 to-purple-600 text-white p-1.5 rounded-md flex items-center justify-center">
                            <i class="bi bi-hexagon-fill text-[14px]"></i>
                        </div>
                        ProMana
                    </a>
                    <div class="flex items-center gap-4">
                        <a asp-controller="Auth" asp-action="Login" class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors">Iniciar Sesión</a>
                        <a asp-controller="Auth" asp-action="Register" class="inline-flex h-9 items-center justify-center rounded-md px-4 py-2 text-sm font-medium text-white shadow transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); box-shadow: 0 0 16px rgba(99,102,241,0.35);">Registrarse</a>
                    </div>
                </header>
            }
            
            <main class="flex-1 w-full mx-auto" id="main-content">
                @if (TempData["Error"] != null)
                {
                    <div class="max-w-md mx-auto mt-6 rounded-md border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300 flex items-center gap-3">
                        <i class="bi bi-exclamation-triangle-fill text-red-400"></i>
                        <span class="font-medium">@TempData["Error"]</span>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    }
    
    <!-- Scripts -->
    <script>
        // Smooth scroll reset to top on HTMX swapped content
        document.body.addEventListener('htmx:afterSettle', function(evt) {
            const mainContent = document.getElementById('main-content');
            if(mainContent) mainContent.scrollTo(0, 0);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
