@model ProjectManagement.Application.DTOs.CreateProjectDto
@{ ViewData["Title"] = "Crear Proyecto"; }

<div class="max-w-xl mx-auto py-8">
    <div class="mb-8">
        <a asp-action="Index" class="inline-flex items-center text-sm font-medium text-slate-400 hover:text-slate-200 transition-colors mb-4">
            <i class="bi bi-arrow-left mr-2"></i> Volver al listado
        </a>
        <h1 class="text-2xl font-bold tracking-tight text-slate-100">Inicializar Proyecto</h1>
        <p class="text-sm text-slate-400 mt-1">Configura un nuevo entorno de trabajo para tu equipo.</p>
    </div>

    <div class="rounded-xl border border-slate-700/50 bg-[#0f1826] shadow-2xl">
        <div class="p-6">
            <form asp-action="Create" method="post" class="space-y-6">

                <div asp-validation-summary="ModelOnly" class="rounded-md border border-red-500/30 bg-red-500/10 p-3 text-sm text-red-300 font-medium"></div>

                <div class="space-y-1.5">
                    <label asp-for="Name" class="text-sm font-medium text-slate-300">Nombre del Proyecto</label>
                    <input asp-for="Name" class="flex h-9 w-full rounded-md border border-slate-700 bg-slate-800/50 px-3 py-1 text-sm text-slate-100 placeholder:text-slate-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" placeholder="Ej: Rediseño App V2024" required />
                    <span asp-validation-for="Name" class="text-[12px] font-medium text-red-400 mt-1 block"></span>
                </div>

                <div class="space-y-1.5">
                    <label asp-for="Description" class="text-sm font-medium text-slate-300">Descripción Contextual <span class="text-slate-500">(Opcional)</span></label>
                    <textarea asp-for="Description" rows="4" class="flex w-full rounded-md border border-slate-700 bg-slate-800/50 px-3 py-2 text-sm text-slate-100 placeholder:text-slate-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500 transition-colors resize-y" placeholder="Describe los OKRs u objetivos principales del proyecto aquí..."></textarea>
                    <span asp-validation-for="Description" class="text-[12px] font-medium text-red-400 mt-1 block"></span>
                </div>

                <div class="pt-4 border-t border-slate-700/50 flex justify-end gap-3">
                    <a asp-action="Index" class="inline-flex h-9 items-center justify-center rounded-md border border-slate-600 bg-slate-800 px-4 py-2 text-sm font-medium text-slate-200 transition-colors hover:bg-slate-700">
                        Cancelar
                    </a>
                    <button type="submit" class="inline-flex h-9 items-center justify-center rounded-md px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition-all hover:opacity-90" style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);">
                        Crear Entorno
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
