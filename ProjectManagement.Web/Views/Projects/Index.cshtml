@using ProjectManagement.Domain.Enums
@model IEnumerable<ProjectManagement.Application.DTOs.ProjectDto>

@{
    ViewData["Title"] = "Workspaces";
    var currentStatus = ViewBag.CurrentStatus as ProjectStatus?;
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
}

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Proyectos</h1>
        <p class="text-sm text-slate-500 mt-1">Navega y administra tus espacios de trabajo actuales.</p>
    </div>
    
    <div class="flex items-center gap-3">
        <!-- View Filters -->
        <form method="get" class="hidden sm:flex items-center border border-slate-200 bg-white rounded-md text-sm p-1 shadow-sm">
            <button type="submit" name="status" value="" class="px-3 py-1.5 rounded-sm font-medium transition-colors @(currentStatus == null ? "bg-slate-100 text-slate-900" : "text-slate-500 hover:text-slate-900")">
                Todos
            </button>
            <button type="submit" name="status" value="1" class="px-3 py-1.5 rounded-sm font-medium transition-colors @(currentStatus == ProjectStatus.Active ? "bg-slate-100 text-slate-900" : "text-slate-500 hover:text-slate-900")">
                Activos
            </button>
            <button type="submit" name="status" value="2" class="px-3 py-1.5 rounded-sm font-medium transition-colors @(currentStatus == ProjectStatus.Completed ? "bg-slate-100 text-slate-900" : "text-slate-500 hover:text-slate-900")">
                Completados
            </button>
        </form>

        <a asp-action="Create" class="inline-flex h-9 items-center justify-center rounded-md bg-indigo-600 px-4 text-sm font-medium text-white shadow-sm transition-colors hover:bg-indigo-700 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-indigo-600 whitespace-nowrap gap-2">
            <i class="bi bi-plus-lg"></i>
            Nuevo Proyecto
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="min-h-[400px] flex flex-col items-center justify-center rounded-lg border border-dashed border-slate-300 bg-white/50 text-center">
        <div class="h-12 w-12 rounded-full bg-slate-100 flex items-center justify-center mb-4">
            <i class="bi bi-folder-x text-xl text-slate-400"></i>
        </div>
        <h3 class="text-lg font-semibold text-slate-900">Ningún espacio de trabajo</h3>
        <p class="text-sm text-slate-500 mt-1 mb-4 max-w-sm">No pudimos encontrar proyectos bajo estos criterios. Puedes comenzar creando uno nuevo.</p>
        <a asp-action="Create" class="inline-flex h-9 items-center justify-center rounded-md bg-white border border-slate-200 px-4 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:bg-slate-100">
            Crear Proyecto
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        @foreach (var p in Model)
        {
            <div class="rounded-xl border border-slate-200 bg-white text-slate-950 shadow-sm hover:border-slate-300 transition-colors flex flex-col group">
                <div class="p-5 flex flex-col flex-grow">
                    <div class="flex justify-between items-start mb-2">
                        <h4 class="font-semibold leading-tight tracking-tight text-lg text-slate-900 truncate pr-4" title="@p.Name">
                            @p.Name
                        </h4>
                        @if (p.Status == ProjectStatus.Draft)
                        {
                            <div class="inline-flex items-center rounded-full border border-slate-200 px-2.5 py-0.5 text-xs font-semibold text-slate-500 bg-slate-50 shrink-0">Borrador</div>
                        }
                        else if (p.Status == ProjectStatus.Active)
                        {
                            <div class="inline-flex items-center rounded-full border-transparent px-2.5 py-0.5 text-xs font-semibold text-indigo-700 bg-indigo-50 shrink-0">Activo</div>
                        }
                        else
                        {
                            <div class="inline-flex items-center rounded-full border-transparent px-2.5 py-0.5 text-xs font-semibold text-emerald-700 bg-emerald-50 shrink-0">Hecho</div>
                        }
                    </div>
                    
                    <p class="text-sm text-slate-500 flex-grow line-clamp-2 mt-2 leading-relaxed h-10">
                        @(string.IsNullOrWhiteSpace(p.Description) ? "Sin descripción general proporcionada." : p.Description)
                    </p>
                </div>
                
                <div class="flex items-center border-t border-slate-100 p-4 bg-slate-50/50 rounded-b-xl gap-2">
                    <a asp-action="Details" asp-route-id="@p.Id" class="inline-flex h-8 items-center justify-center rounded-md border border-slate-200 bg-white px-3 text-xs font-medium text-slate-900 shadow-sm transition-colors hover:bg-slate-100 hover:text-slate-900 mr-auto">
                        Aperturar Board
                    </a>
                    
                    <a asp-action="Edit" asp-route-id="@p.Id" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-slate-500 hover:bg-slate-200 hover:text-slate-900 transition-colors opacity-0 group-hover:opacity-100" title="Ajustes">
                        <i class="bi bi-sliders"></i>
                    </a>
                    
                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="m-0 opacity-0 group-hover:opacity-100" onsubmit="return confirm('¿Eliminar archivo permanentemente?');">
                        <button type="submit" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-red-500 hover:bg-red-100 transition-colors" title="Destruir">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="mt-8 flex justify-center">
            <nav class="inline-flex -space-x-px rounded-md shadow-sm">
                <a asp-route-status="@currentStatus" asp-route-page="@(currentPage - 1)" class="inline-flex items-center rounded-l-md border border-slate-200 bg-white px-2.5 py-2 text-sm font-medium text-slate-500 hover:bg-slate-50 @(currentPage == 1 ? "pointer-events-none opacity-50" : "")">
                    <span class="sr-only">Previous</span>
                    <i class="bi bi-chevron-left"></i>
                </a>
                
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a asp-route-status="@currentStatus" asp-route-page="@i" class="inline-flex items-center border px-4 py-2 text-sm font-medium @(currentPage == i ? "z-10 bg-slate-100 border-slate-300 text-slate-900" : "bg-white border-slate-200 text-slate-500 hover:bg-slate-50")">
                        @i
                    </a>
                }
                
                <a asp-route-status="@currentStatus" asp-route-page="@(currentPage + 1)" class="inline-flex items-center rounded-r-md border border-slate-200 bg-white px-2.5 py-2 text-sm font-medium text-slate-500 hover:bg-slate-50 @(currentPage == totalPages ? "pointer-events-none opacity-50" : "")">
                    <span class="sr-only">Next</span>
                    <i class="bi bi-chevron-right"></i>
                </a>
            </nav>
        </div>
    }
}
