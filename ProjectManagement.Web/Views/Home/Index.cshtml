@{ ViewData["Title"] = "Plataforma de Gestión Profesional"; }

<section class="w-full py-20 md:py-32 lg:py-48 flex flex-col items-center justify-center text-center px-4 md:px-6">
    <div class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm font-medium transition-colors hover:bg-slate-100 mb-8 cursor-pointer">
        <span class="flex h-2 w-2 rounded-full bg-indigo-600 mr-2"></span>
        <span>ProMana 2.0 está disponible</span>
        <i class="bi bi-arrow-right ml-2 text-slate-400"></i>
    </div>
    
    <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl text-slate-900 max-w-4xl mx-auto mb-6">
        Software para equipos <br class="hidden sm:inline" />
        <span class="text-indigo-600">orientados a resultados</span>
    </h1>
    
    <p class="mx-auto max-w-[700px] text-slate-500 md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed mb-10">
        Una plataforma diseñada meticulosamente para profesionales. Planifica, gestiona y entrega tus proyectos en un entorno veloz, sin recargas y enfocado en la productividad pura.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full max-w-sm sm:max-w-none">
        <a asp-controller="Auth" asp-action="Register" class="inline-flex h-11 items-center justify-center rounded-md bg-slate-900 px-8 py-2 text-sm font-medium text-slate-50 shadow transition-colors hover:bg-slate-900/90 w-full sm:w-auto focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400">
            Comenzar Ahora
        </a>
        <a asp-controller="Auth" asp-action="Login" class="inline-flex h-11 items-center justify-center rounded-md border border-slate-200 bg-white px-8 py-2 text-sm font-medium text-slate-900 shadow-sm transition-colors hover:bg-slate-100 w-full sm:w-auto focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400">
            Iniciar Sesión
        </a>
    </div>
</section>

<section class="w-full py-20 bg-slate-50 border-t border-slate-200 px-4 md:px-6">
    <div class="mx-auto max-w-6xl grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <div class="rounded-xl border border-slate-200 bg-white text-slate-950 shadow-sm">
            <div class="p-6 flex flex-col items-start gap-4">
                <div class="bg-slate-100 p-2.5 rounded-lg border border-slate-200">
                    <i class="bi bi-kanban text-lg text-slate-700"></i>
                </div>
                <div>
                    <h3 class="font-semibold leading-none tracking-tight mb-2">Flujos Ágiles</h3>
                    <p class="text-sm text-slate-500">Diseñado para adaptarse a tus iteraciones. Administra todo el ciclo de vida del trabajo con velocidad nativa.</p>
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white text-slate-950 shadow-sm">
            <div class="p-6 flex flex-col items-start gap-4">
                <div class="bg-indigo-50 p-2.5 rounded-lg border border-indigo-100">
                    <i class="bi bi-bar-chart-fill text-lg text-indigo-600"></i>
                </div>
                <div>
                    <h3 class="font-semibold leading-none tracking-tight mb-2">Toma de Decisiones</h3>
                    <p class="text-sm text-slate-500">Obtén estado en tiempo real. Visualiza cuantas tareas faltan sin navegar por interfaces ruidosas.</p>
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white text-slate-950 shadow-sm">
            <div class="p-6 flex flex-col items-start gap-4">
                <div class="bg-slate-900 p-2.5 rounded-lg border border-slate-800">
                    <i class="bi bi-shield-check text-lg text-slate-50"></i>
                </div>
                <div>
                    <h3 class="font-semibold leading-none tracking-tight mb-2">Calidad Empresarial</h3>
                    <p class="text-sm text-slate-500">Arquitectura Clean en .NET y diseño meticuloso para garantizar que los equipos de ingeniería amen usarla.</p>
                </div>
            </div>
        </div>

    </div>
</section>

<footer class="w-full py-6 md:py-12 border-t border-slate-200 bg-white">
    <div class="container mx-auto flex flex-col md:flex-row items-center justify-between px-4 md:px-6 text-sm text-slate-500">
        <div class="flex items-center gap-2 font-medium text-slate-900">
            <div class="bg-slate-900 text-white p-1 rounded flex items-center justify-center">
                <i class="bi bi-hexagon-fill text-[10px]"></i>
            </div>
            ProMana
        </div>
        <p class="mt-4 md:mt-0">&copy; @DateTime.Now.Year. Construido con rigor ingenieril.</p>
    </div>
</footer>
