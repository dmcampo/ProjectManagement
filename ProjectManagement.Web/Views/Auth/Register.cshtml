@model ProjectManagement.Application.DTOs.UserRegisterDto
@{ ViewData["Title"] = "Registrarse"; }

<div class="auth-page">
    <!-- Decorative elements matching landing page -->
    <div class="glow-orb glow-orb--purple" style="width:400px;height:400px;top:-120px;left:-80px;"></div>
    <div class="glow-orb glow-orb--blue" style="width:350px;height:350px;bottom:-100px;right:-60px;"></div>
    <div class="grid-pattern"></div>

    <div class="auth-container auth-animate">
        <div class="auth-header">
            <div class="auth-logo">
                <i class="bi bi-hexagon-fill"></i>
            </div>
            <h1 class="auth-title">Únete a ProMana</h1>
            <p class="auth-subtitle">Crea un espacio de trabajo para ti y tu equipo.</p>
        </div>

        <div class="auth-card">
            <form asp-action="Register" method="post" class="auth-form">

                <div asp-validation-summary="ModelOnly" class="auth-error-box"></div>

                <div class="form-group">
                    <label asp-for="Name" class="form-label">Nombre Completo</label>
                    <div class="input-wrapper">
                        <i class="bi bi-person input-icon"></i>
                        <input asp-for="Name" type="text" class="form-input" placeholder="Ingeniero de Software" required />
                    </div>
                    <span asp-validation-for="Name" class="form-validation"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Correo Electrónico</label>
                    <div class="input-wrapper">
                        <i class="bi bi-envelope input-icon"></i>
                        <input asp-for="Email" type="email" class="form-input" placeholder="nombre@empresa.com" required />
                    </div>
                    <span asp-validation-for="Email" class="form-validation"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Contraseña</label>
                    <div class="input-wrapper">
                        <i class="bi bi-lock input-icon"></i>
                        <input asp-for="Password" type="password" class="form-input" placeholder="Mínimo 8 caracteres" required />
                    </div>
                    <span asp-validation-for="Password" class="form-validation"></span>
                </div>

                <div class="form-action">
                    <button type="submit" class="btn btn--primary btn--full">
                        <i class="bi bi-rocket-takeoff-fill"></i>
                        Crear Cuenta
                    </button>
                </div>
            </form>

            <div class="auth-footer">
                ¿Ya tienes una cuenta?
                <a asp-action="Login" class="auth-link">Iniciar Sesión</a>
            </div>
        </div>

    </div>
</div>
