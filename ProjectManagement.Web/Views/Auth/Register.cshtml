@model ProjectManagement.Application.DTOs.UserRegisterDto
@{ ViewData["Title"] = "Registrarse"; }

<div class="flex flex-col items-center justify-center min-h-[80vh] py-12 px-4 sm:px-6 lg:px-8 w-full">
    <div class="w-full max-w-[440px]">
        
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">Únete a ProMana</h1>
            <p class="text-sm text-slate-500 mt-2">Crea un espacio de trabajo para ti y tu equipo.</p>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8">
            <form asp-action="Register" method="post" class="space-y-5">
                
                <div asp-validation-summary="ModelOnly" class="rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-800 font-medium"></div>

                <div class="space-y-2">
                    <label asp-for="Name" class="text-sm font-medium leading-none text-slate-900">Nombre Completo</label>
                    <input asp-for="Name" type="text" class="flex h-10 w-full rounded-md border border-slate-200 bg-transparent px-3 py-2 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-colors shadow-sm" placeholder="Ingeniero de Software" required />
                    <span asp-validation-for="Name" class="text-[12px] font-medium text-red-500 block"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Email" class="text-sm font-medium leading-none text-slate-900">Correo Electrónico</label>
                    <input asp-for="Email" type="email" class="flex h-10 w-full rounded-md border border-slate-200 bg-transparent px-3 py-2 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-colors shadow-sm" placeholder="nombre@empresa.com" required />
                    <span asp-validation-for="Email" class="text-[12px] font-medium text-red-500 block"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Password" class="text-sm font-medium leading-none text-slate-900">Contraseña</label>
                    <input asp-for="Password" type="password" class="flex h-10 w-full rounded-md border border-slate-200 bg-transparent px-3 py-2 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-colors shadow-sm" required />
                    <span asp-validation-for="Password" class="text-[12px] font-medium text-red-500 block"></span>
                </div>

                <div class="pt-2">
                    <button type="submit" class="inline-flex h-10 w-full items-center justify-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-slate-50 shadow transition-colors hover:bg-slate-900/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-950">
                        Crear Cuenta
                    </button>
                </div>
                
            </form>

            <div class="mt-6 text-center text-sm text-slate-500">
                ¿Ya tienes una cuenta? 
                <a asp-action="Login" class="font-medium text-indigo-600 hover:text-indigo-500 hover:underline">Iniciar Sesión</a>
            </div>
        </div>
    </div>
</div>
