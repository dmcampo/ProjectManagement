@model ProjectManagement.Application.DTOs.UserLoginDto
@{ ViewData["Title"] = "Iniciar Sesión"; }

<div class="auth-page">
    <!-- Decorative elements matching landing page -->
    <div class="glow-orb glow-orb--purple" style="width:400px;height:400px;top:-120px;right:-80px;"></div>
    <div class="glow-orb glow-orb--blue" style="width:350px;height:350px;bottom:-100px;left:-60px;"></div>
    <div class="grid-pattern"></div>

    <div class="auth-container auth-animate">
        <div class="auth-header">
            <div class="auth-logo">
                <i class="bi bi-hexagon-fill"></i>
            </div>
            <h1 class="auth-title">Bienvenido de nuevo</h1>
            <p class="auth-subtitle">Ingresa tus credenciales para acceder a tu entorno.</p>
        </div>

        <div class="auth-card">
            <form asp-action="Login" method="post" class="auth-form">

                <div asp-validation-summary="ModelOnly" class="auth-error-box"></div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Correo Electrónico</label>
                    <div class="input-wrapper">
                        <i class="bi bi-envelope input-icon"></i>
                        <input asp-for="Email" type="email" class="form-input" placeholder="usuario@empresa.com" required />
                    </div>
                    <span asp-validation-for="Email" class="form-validation"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Contraseña</label>
                    <div class="input-wrapper">
                        <i class="bi bi-lock input-icon"></i>
                        <input asp-for="Password" type="password" class="form-input" placeholder="••••••••" required />
                    </div>
                    <span asp-validation-for="Password" class="form-validation"></span>
                </div>

                <div class="form-action">
                    <button type="submit" class="btn btn--primary btn--full">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Iniciar Sesión
                    </button>
                </div>
            </form>

            <div class="auth-footer">
                ¿No tienes una cuenta?
                <a asp-action="Register" class="auth-link">Regístrate</a>
            </div>
        </div>
    </div>
</div>
